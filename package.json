    "recharts": "^2.7.2",
    "axios": "^1.4.0",
    "date-fns": "^2.30.0",
    "react-query": "^3.39.3",
    "react-hot-toast": "^2.4.1",
    "framer-motion": "^10.16.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@types/jest": "^29.5.3",
    "eslint": "^8.57.1",
    "eslint-config-next": "^15.5.12",
