{
  "name": "metaforge-gaming-platform",
  "version": "1.0.0",
  "private": true,
  "description": "Advanced gaming analytics and build optimization platform",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
